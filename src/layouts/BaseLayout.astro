---
import '../styles/global.css';
import { site, navItems, type NavKey } from '../site';

interface Props {
  title?: string;
  description?: string;
  current?: NavKey;
  /** Path of the current page, for canonical/og url */
  path?: string;
  /** Override OG image (defaults to site.ogImage) */
  ogImage?: string;
  /** Article-level og data (for blog posts) */
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    tags?: string[];
  };
}

const {
  title,
  description = site.description,
  current,
  path = Astro.url.pathname,
  ogImage = site.ogImage,
  article,
} = Astro.props;

const fullTitle = title ? `${title} — ${site.title}` : `${site.title} — Solution Architect & Engineering Lead`;
const canonical = new URL(path, site.url).toString();
const ogUrl = new URL(ogImage, site.url).toString();
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="color-scheme" content="dark light" />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <meta property="og:type" content={article ? 'article' : 'website'} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogUrl} />
  <meta property="og:site_name" content={site.title} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogUrl} />
  <meta name="twitter:creator" content="@nzmrldev" />

  {article?.publishedTime && <meta property="article:published_time" content={article.publishedTime} />}
  {article?.modifiedTime && <meta property="article:modified_time" content={article.modifiedTime} />}
  {article?.tags?.map(tag => <meta property="article:tag" content={tag} />)}

  <link rel="alternate" type="application/rss+xml" title={`${site.title} — writing`} href="/feed.xml" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  <script is:inline>
    // No-FOUC theme bootstrap. Runs synchronously before first paint.
    // Dark wins on first visit unless the OS prefers light.
    (function () {
      try {
        var stored = localStorage.getItem('theme');
        var theme;
        if (stored === 'light' || stored === 'dark') {
          theme = stored;
        } else {
          var prefersLight = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches;
          theme = prefersLight ? 'light' : 'dark';
        }
        document.documentElement.setAttribute('data-theme', theme);
      } catch (_) {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    })();
  </script>
</head>
<body>
  <div class="mx-auto max-w-page px-page" style="padding-left: 64px; padding-right: 64px; padding-top: 56px; padding-bottom: 56px;">
    <nav class="navbar bd-h" style="border-bottom: 1px solid var(--hairline); padding-bottom: 18px;">
      <a href="/" class="lk" style="color: var(--text); font-weight: 600; font-size: 14px;">
        {site.shortTitle} <span class="text-muted" style="font-weight: 400;">/ {site.initials}</span>
      </a>
      <div class="flex items-center gap-7">
        {navItems.map(item => (
          <a href={item.href} class={current === item.key ? 'current' : 'lk'}>{item.label}</a>
        ))}
        <span class="text-muted ml-2 tnum" style="font-size: 12px;">{site.coordinate}</span>
        <button
          id="theme-toggle"
          type="button"
          class="lk"
          aria-label="Toggle colour theme"
          title="Toggle colour theme (t)"
          style="font-size: 12px; background: transparent; border: 1px solid var(--border); padding: 2px 8px; border-radius: 3px; cursor: pointer;"
        >
          <span data-theme-label-dark>dark</span>
          <span data-theme-label-light style="display:none;">light</span>
        </button>
      </div>
    </nav>

    <slot />
  </div>

  <script is:inline>
    (function () {
      var btn = document.getElementById('theme-toggle');
      if (!btn) return;
      var labelDark = btn.querySelector('[data-theme-label-dark]');
      var labelLight = btn.querySelector('[data-theme-label-light]');
      function sync() {
        var t = document.documentElement.getAttribute('data-theme') || 'dark';
        if (labelDark && labelLight) {
          labelDark.style.display  = t === 'dark'  ? '' : 'none';
          labelLight.style.display = t === 'light' ? '' : 'none';
        }
      }
      sync();
      function toggle() {
        var cur = document.documentElement.getAttribute('data-theme') || 'dark';
        var next = cur === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        try { localStorage.setItem('theme', next); } catch (_) {}
        sync();
      }
      btn.addEventListener('click', toggle);
      window.addEventListener('keydown', function (e) {
        var tag = (e.target && e.target.tagName) || '';
        if (e.key === 't' && !e.metaKey && !e.ctrlKey && !e.altKey && tag !== 'INPUT' && tag !== 'TEXTAREA') {
          toggle();
        }
      });
    })();
  </script>
</body>
</html>
