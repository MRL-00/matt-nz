---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../site';
import { readingStats, formatWords } from '../../lib/reading';

export async function getStaticPaths() {
  const posts = (await getCollection('writing', ({ data }) => !data.draft))
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: posts[i + 1] ?? null,
      next: posts[i - 1] ?? null,
    },
  }));
}

type Props = {
  post: CollectionEntry<'writing'>;
  prev: CollectionEntry<'writing'> | null;
  next: CollectionEntry<'writing'> | null;
};

const { post, prev, next } = Astro.props as Props;
const { Content, headings } = await render(post);
const stats = readingStats(post.body ?? '');

const d = post.data.date;
const yyyy = d.getFullYear();
const mm = String(d.getMonth() + 1).padStart(2, '0');
const dd = String(d.getDate()).padStart(2, '0');
const dateStr = `${yyyy}-${mm}-${dd}`;

const editedStr = post.data.edited
  ? (() => {
      const e = post.data.edited;
      return `${e.getFullYear()}-${String(e.getMonth() + 1).padStart(2, '0')}-${String(e.getDate()).padStart(2, '0')}`;
    })()
  : null;

// Only collect h2s for the TOC (mockup shows section-level only).
const toc = headings.filter(h => h.depth === 2);

function fmt(p: CollectionEntry<'writing'>) {
  const dt = p.data.date;
  return `${dt.getFullYear()}-${String(dt.getMonth() + 1).padStart(2, '0')}-${String(dt.getDate()).padStart(2, '0')}`;
}
---
<BaseLayout
  title={post.data.title}
  description={post.data.excerpt}
  current="writing"
  article={{
    publishedTime: d.toISOString(),
    modifiedTime: post.data.edited?.toISOString(),
    tags: post.data.tags,
  }}
>
  <div class="grid grid-cols-12 gap-14 mt-16 grid-main">
    <aside class="col-span-4">
      <div class="id-card">
        <a href="/writing" class="lk" style="font-size: 13px;">← back to writing</a>
        <div class="text-muted tnum mt-2" style="font-size: 12px;">writing / {yyyy} / {mm}</div>

        <div class="text-muted uppercase mb-4 mt-8" style="font-size: 11px; letter-spacing: 0.18em;">~/ post</div>
        <div class="row"><span class="k">date</span><span class="v tnum">{dateStr}</span></div>
        <div class="row"><span class="k">read</span><span class="v tnum">{stats.minutes} min · {formatWords(stats.words)} words</span></div>
        {editedStr && <div class="row"><span class="k">edited</span><span class="v tnum">{editedStr}</span></div>}
        <div class="row"><span class="k">tags</span><span class="v">{post.data.tags.map(t => <span class="tag mr-2">{t}</span>)}</span></div>
        {post.data.location && <div class="row"><span class="k">from</span><span class="v">{post.data.location}</span></div>}

        {toc.length > 0 && (
          <>
            <div class="text-muted uppercase mb-3 mt-8" style="font-size: 11px; letter-spacing: 0.18em;">~/ contents</div>
            <ol id="toc" class="tnum" style="font-size: 13px; line-height: 1.85; list-style: none; padding: 0;">
              {toc.map((h, i) => (
                <li>
                  <a href={`#${h.slug}`} class="lk toc-link text-dim" data-target={h.slug}>
                    <span class="text-muted">{String(i + 1).padStart(2, '0')}</span>&nbsp; {h.text}
                  </a>
                </li>
              ))}
            </ol>
          </>
        )}

        <div class="text-muted uppercase mb-3 mt-8" style="font-size: 11px; letter-spacing: 0.18em;">~/ share</div>
        <div style="font-size: 13px; line-height: 1.85;">
          <button id="copy-link" class="lk-u" style="background:none;border:none;padding:0;cursor:pointer;font:inherit;color:inherit;">copy link</button><br/>
          <a class="lk-u" href={`https://x.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(new URL(`/writing/${post.id}`, site.url).toString())}`}>x / @nzmrldev →</a><br/>
          <a class="lk-u" href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(new URL(`/writing/${post.id}`, site.url).toString())}`}>linkedin →</a>
        </div>
      </div>
    </aside>

    <article class="col-span-8">
      <div class="text-muted uppercase mb-3" style="font-size: 11px; letter-spacing: 0.18em;">~/ writing / {yyyy}</div>

      <h1 class="font-semibold" style="font-size: 30px; line-height: 1.2; letter-spacing: -0.02em; max-width: 32ch;">
        {post.data.title}
      </h1>

      <div class="mt-3 tnum text-muted" style="font-size: 12px;">
        <span>{dateStr}</span>
        <span class="mx-2">·</span>
        <span>{stats.minutes} min</span>
        <span class="mx-2">·</span>
        <span>{formatWords(stats.words)} words</span>
        {post.data.location && (
          <>
            <span class="mx-2">·</span>
            <span>{post.data.location}</span>
          </>
        )}
      </div>

      <div class="ascii-rule mt-3">────────────────────────────────────────────────────────────────────</div>

      <div class="prose-body mt-6">
        <Content />
      </div>

      <div class="ascii-rule mt-12">────────────────────────────────────────────────────────────────────</div>

      <p class="mt-6" style="font-size: 14px; color: var(--text-dim); max-width: 70ch; line-height: 1.65;">
        If you&rsquo;ve got opinions about this &mdash; agreement, disagreement, war stories &mdash; I read every reply on
        <a href="https://x.com/nzmrldev" class="lk-u">x / @nzmrldev</a> and on
        <a href="https://www.linkedin.com/in/mrlist/" class="lk-u">linkedin</a>.
      </p>

      <nav class="grid grid-cols-2 gap-8 mt-12 pt-8" style="border-top: 1px solid var(--hairline);">
        <div>
          {prev ? (
            <a href={`/writing/${prev.id}`} class="lk block">
              <span class="text-muted" style="font-size: 12px;">← previous</span>
              <span class="block mt-1" style="color: var(--text); font-size: 14px; font-weight: 600;">{prev.data.title}</span>
              <span class="text-muted tnum block mt-1" style="font-size: 12px;">{fmt(prev)}</span>
            </a>
          ) : <span class="text-muted" style="font-size: 12px;">← previous</span>}
        </div>
        <div class="text-right">
          {next ? (
            <a href={`/writing/${next.id}`} class="lk block">
              <span class="text-muted" style="font-size: 12px;">next →</span>
              <span class="block mt-1" style="color: var(--text); font-size: 14px; font-weight: 600;">{next.data.title}</span>
              <span class="text-muted tnum block mt-1" style="font-size: 12px;">{fmt(next)}</span>
            </a>
          ) : <span class="text-muted" style="font-size: 12px;">next →</span>}
        </div>
      </nav>

      <div class="page-spec mt-16 tnum">
        <span>{site.url.replace('https://', '')} / writing / {post.id}</span>
        <span>{stats.minutes} min · {formatWords(stats.words)} words</span>
      </div>
    </article>
  </div>

  <script is:inline>
    (function () {
      // copy link
      var btn = document.getElementById('copy-link');
      if (btn) {
        btn.addEventListener('click', function () {
          var url = window.location.href;
          if (navigator.clipboard) {
            navigator.clipboard.writeText(url).then(function () {
              var orig = btn.textContent;
              btn.textContent = 'copied ✓';
              setTimeout(function () { btn.textContent = orig; }, 1400);
            });
          }
        });
      }

      // scroll-spy on H2s
      var links = Array.prototype.slice.call(document.querySelectorAll('.toc-link'));
      if (!links.length || !('IntersectionObserver' in window)) return;

      var idToLink = {};
      links.forEach(function (a) {
        var t = a.getAttribute('data-target');
        if (t) idToLink[t] = a;
      });

      var headings = links
        .map(function (a) { return document.getElementById(a.getAttribute('data-target')); })
        .filter(Boolean);

      function setActive(id) {
        links.forEach(function (a) {
          var active = a.getAttribute('data-target') === id;
          a.classList.toggle('text-dim', !active);
          a.style.color = active ? 'var(--text)' : '';
        });
      }

      var visible = new Set();
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) visible.add(e.target.id);
          else visible.delete(e.target.id);
        });
        var first = headings.find(function (h) { return visible.has(h.id); });
        if (first) setActive(first.id);
      }, { rootMargin: '0px 0px -70% 0px', threshold: 0.1 });
      headings.forEach(function (h) { io.observe(h); });
    })();
  </script>
</BaseLayout>
